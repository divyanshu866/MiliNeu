@model IEnumerable<MiliNeu.Models.Order>

@{
    ViewData["Title"] = "Index";
}
<div class="page-header order-background">
    <h1 class="">Your Orders</h1>
</div>





<div class="orders-wrapper">
   @*  <div class="project">
        <div class="shop">

        <div class="box">
 *@
    
    <div class="orders-headings">
        @* <div class="icon-headings"> *@
           
