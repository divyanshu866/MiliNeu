@model MiliNeu.Models.Collection

@{
    ViewData["Title"] = "Create";
}

<h1>@(Model.Id!=0?"Update":"Create")</h1>

<h4>Collection</h4>
<hr />
<div class="row">
    <div class="col-lg-5 col-md-4 col-6 mb-1">
        <div  style="width: 100%; content-visibility: auto">
            @if (Model.Id == 0 || Model.Id == null)
            {
                <img src="\Resources\Images\Common\Image-Placeholder.jpg" onerror="this.src='';" alt="Image" class="img-fluid">
            }
            else
            {
                <img src="@Model.Path" alt="Image" class="img-fluid">
            }
        </div>
    </div>
    <div class="col-md-4">
        <form asp-action="Upsert" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <input asp-for="Id" hidden disabled/>
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Category" class="control-label"></label>
                <input asp-for="Category" class="form-control" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Path"  class="control-label"></label>
                <input asp-for="Path" hidden type="text" class="form-control" />
                <input name="file" type="file" class="form-control" />
                <span asp-validation-for="Path" class="text-danger"></span>
            </div>
            <div class="form-group">
                @if(Model.Id==null || Model.Id == 0)
                {
                    <input type="submit" value="Create" class="btn btn-primary" />
                }
                else
                {
                    <input type="submit" value="Update" class="btn btn-primary" />
                }

            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
